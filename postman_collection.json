          }
        },
        {
          "name": "Detalhes da Trilha",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/content/trails/{{trail_id}}", "host": ["{{base_url}}"], "path": ["content", "trails", "{{trail_id}}"] }
          }
        },
        {
          "name": "Detalhes da Lição (com exercícios)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/content/lessons/{{lesson_id}}", "host": ["{{base_url}}"], "path": ["content", "lessons", "{{lesson_id}}"] }
          }
