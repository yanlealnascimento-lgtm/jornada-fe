            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data?._id) pm.collectionVariables.set('exercise_id', r.data._id);"
                ],
                "type": "text/javascript"
              }
            }]
          }
        },
