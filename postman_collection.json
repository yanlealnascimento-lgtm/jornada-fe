            "url": { "raw": "{{base_url}}/admin/exercises", "host": ["{{base_url}}"], "path": ["admin", "exercises"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"audio_recite\",\n  \"question\": \"Recite o versículo em voz alta:\",\n  \"options_text\": [],\n  \"correct_answer\": \"porque deus amou o mundo de tal maneira que deu o seu filho unigênito\",\n  \"explanation\": \"João 3:16 é um dos versículos mais conhecidos da Bíblia.\",\n  \"verse_reference\": \"João 3:16\",\n  \"level\": 2,\n  \"xp_reward\": 30,\n  \"order\": 37,\n  \"is_active\": true,\n  \"is_premium\": true\n}"
