              "path": ["admin", "exercises"],
              "query": [
                { "key": "level", "value": "1", "disabled": true },
                { "key": "type", "value": "multiple_choice", "disabled": true },
                { "key": "is_premium", "value": "false", "disabled": true },
                { "key": "is_active", "value": "true", "disabled": true },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "limit", "value": "50", "disabled": true }
