{
  "info": {
    "name": "JourneyFaith API",
    "_postman_id": "jf-api-collection-v1",
    "description": "Collection completa da API JourneyFaith — Auth, Exercises, User Progress, Content, Gamification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api/v1", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "user_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "exercise_id", "value": "", "type": "string" },
    { "key": "trail_id", "value": "", "type": "string" },
    { "key": "character_id", "value": "", "type": "string" },
    { "key": "achievement_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Isaias Silva\",\n  \"email\": \"isaiasilva@gmail.com\",\n  \"password\": \"Is@i@s1989\",\n  \"denomination\": \"evangelical\",\n  \"daily_goal_minutes\": 10\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "if (r.data?.token) pm.collectionVariables.set('user_token', r.data.token);",
                "if (r.data?.user?.id) pm.collectionVariables.set('user_id', r.data.user.id);"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"isaiasilva@gmail.com\",\n  \"password\": \"Is@i@s1989\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "if (r.data?.token) pm.collectionVariables.set('user_token', r.data.token);",
                "if (r.data?.user?.id) pm.collectionVariables.set('user_id', r.data.user.id);"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@journeyfaith.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "if (r.data?.token) pm.collectionVariables.set('admin_token', r.data.token);",
                "if (r.data?.user?.id) pm.collectionVariables.set('user_id', r.data.user.id);"
              ],
              "type": "text/javascript"
            }
          }]
        },
