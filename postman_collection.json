            "url": { "raw": "{{base_url}}/content/lessons/{{lesson_id}}/complete", "host": ["{{base_url}}"], "path": ["content", "lessons", "{{lesson_id}}", "complete"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"xp_earned\": 15,\n  \"mistakes\": 1,\n  \"time_seconds\": 120\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Exercises (Public)",
      "item": [
        {
          "name": "Listar Exercícios Ativos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/exercises",
              "host": ["{{base_url}}"],
              "path": ["exercises"],
              "query": [
                { "key": "level", "value": "1", "disabled": true },
                { "key": "type", "value": "multiple_choice", "disabled": true },
                { "key": "limit", "value": "50", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Buscar Exercício por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/exercises/{{exercise_id}}", "host": ["{{base_url}}"], "path": ["exercises", "{{exercise_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Exercises (Admin CRUD)",
