# ==========================================
# JourneyFaith — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ==========================================

# Servidor
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://journeyfaith:jf_dev_2025@localhost:27017/journeyfaith_dev?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT (preparado — middleware não ativo no MVP)
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Cloud Messaging (Push Notifications — Prompt 18)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# AWS S3 (ou Cloudflare R2) — Storage de mídia
AWS_S3_BUCKET=journeyfaith-media
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_PUBLIC_URL=https://media.journeyfaith.com

# Regras de negócio
MAX_HEARTS=5
HEARTS_RECHARGE_MINUTES=30
LEAGUE_SIZE=30
STREAK_FREEZE_COST_MANA=1
XP_PER_LESSON=15
XP_PER_PERFECT_LESSON=25
